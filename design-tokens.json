{
  "name": "hungun-tsagaan-hiits",
  "direction": "Data Precision",
  "colors": {
    "background": "#0A0A0F",
    "surface": "#1A1A22",
    "surfaceElevated": "#23232E",
    "accent": "#2563EB",
    "accentHover": "#1D4ED8",
    "text": "#FAFAFA",
    "textMuted": "#A1A1AA",
    "textSubtle": "#71717A",
    "border": "#27272A",
    "success": "#22C55E",
    "warning": "#EAB308",
    "error": "#EF4444"
  },
  "typography": {
    "sans": "Inter, system-ui, sans-serif",
    "mono": "JetBrains Mono, ui-monospace, monospace",
    "headingWeight": 600,
    "bodyWeight": 400,
    "lineHeight": 1.6,
    "headingLineHeight": 1.2
  },
  "spacing": {
    "section": "6rem",
    "sectionDesktop": "8rem",
    "container": "80rem",
    "containerPadding": "1.5rem"
  },
  "motion": {
    "level": 2,
    "duration": {
      "fast": 0.2,
      "normal": 0.5,
      "slow": 0.8
    },
    "easing": "[0.22, 1, 0.36, 1]",
    "stagger": 0.08
  },
  "radius": {
    "small": "0.25rem",
    "medium": "0.5rem",
    "large": "0.75rem"
  }
}
